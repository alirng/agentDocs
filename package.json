{
  "name": "agentdocs",
  "version": "0.1.0",
  "private": true,
  "description": "Markdown-compatible rich documents for AI agents and humans.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alirng/agentDocs.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "agentdocs": "node packages/cli/dist/index.js",
    "agd": "node packages/cli/dist/index.js",
    "build": "pnpm -r build",
    "build:examples": "node scripts/build-examples.mjs",
    "clean": "pnpm -r clean && rm -rf dist",
    "lint": "pnpm typecheck",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
