{
  "name": "@agentdocs0/renderer-html",
  "version": "0.1.0",
  "description": "Self-contained HTML renderer for agentDocs Markdown.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alirng/agentDocs.git",
    "directory": "packages/renderer-html"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentdocs0/core": "workspace:*",
    "@agentdocs0/themes": "workspace:*"
  }
}
